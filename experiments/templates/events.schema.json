{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Co-Bot Evidence Event",
  "type": "object",
  "required": [
    "timestamp",
    "module",
    "event",
    "session_id",
    "task_id",
    "correlation_id",
    "state"
  ],
  "properties": {
    "timestamp": {"type": "string"},
    "module": {
      "enum": [
        "backend-api",
        "supervisor",
        "policy-gate",
        "social-agent",
        "action-agent",
        "robot-mcp",
        "perception",
        "checkpoint",
        "memory"
      ]
    },
    "event": {"type": "string"},
    "session_id": {"type": "string"},
    "task_id": {"type": "string"},
    "correlation_id": {"type": "string"},
    "state": {"type": "string"},
    "payload": {"type": "object"}
  },
  "additionalProperties": false
}
