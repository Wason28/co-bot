{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Co-Bot Evidence Metadata",
  "type": "object",
  "required": [
    "scenario_id",
    "run_id",
    "attempt_index",
    "benchmark_version",
    "operator",
    "created_at",
    "model_versions",
    "device_versions"
  ],
  "properties": {
    "scenario_id": {"type": "string"},
    "run_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "attempt_index": {"type": "integer", "minimum": 1, "maximum": 3},
    "benchmark_version": {"type": "string"},
    "operator": {"type": "string"},
    "created_at": {"type": "string"},
    "model_versions": {
      "type": "object",
      "required": ["supervisor", "social", "action"],
      "properties": {
        "supervisor": {"type": "string"},
        "social": {"type": "string"},
        "action": {"type": "string"}
      }
    },
    "device_versions": {
      "type": "object",
      "required": ["robot_arm", "wrist_camera", "laptop_camera"],
      "properties": {
        "robot_arm": {"type": "string"},
        "wrist_camera": {"type": "string"},
        "laptop_camera": {"type": "string"}
      }
    }
  },
  "additionalProperties": false
}
