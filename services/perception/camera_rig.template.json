{
  "rig_id": "dual-camera-desktop-rig",
  "deployment_mode": "hybrid",
  "capture_backend": "opencv-placeholder",
  "supported_scenarios": [
    "demo-full-flow",
    "demo-sorting",
    "demo-conversation-grasp",
    "demo-real-risk-slice"
  ],
  "streams": [
    {
      "camera_id": "wrist-camera",
      "device_selector": "usb-index-0",
      "role": "fine-manipulation",
      "frame_format": "jpeg",
      "resolution": {
        "width": 640,
        "height": 480
      }
    },
    {
      "camera_id": "laptop-camera",
      "device_selector": "builtin-index-0",
      "role": "global-view",
      "frame_format": "jpeg",
      "resolution": {
        "width": 1280,
        "height": 720
      }
    }
  ],
  "fusion": {
    "primary_stream": "wrist-camera",
    "context_stream": "laptop-camera",
    "sync_tolerance_ms": 250
  },
  "camera_switching": {
    "operator_default": "laptop-camera",
    "manipulation_default": "wrist-camera",
    "preserve_prompt_visibility": true
  },
  "face_following": {
    "enabled_for": [
      "demo-full-flow",
      "demo-conversation-grasp"
    ],
    "handoff_path": [
      "laptop-camera",
      "wrist-camera"
    ]
  },
  "recording": {
    "frame_event_log_path": "logs/camera-frames/<run-id>.jsonl",
    "video_bundle_dir": "experiments/evidence/<scenario-id>/<run-id>/video"
  }
}
