{
  "version": "m2-lane1-v2",
  "mode": "dual-camera-hybrid-ready",
  "streams": [
    {
      "camera_id": "wrist-camera",
      "role": "fine-manipulation",
      "device_kind": "usb",
      "frame_format": "jpeg",
      "capture_profile": "640x480@15",
      "required_for": [
        "demo-full-flow",
        "demo-conversation-grasp",
        "demo-sorting",
        "demo-real-risk-slice"
      ],
      "evidence_artifacts": [
        "perception/frame-sources.json",
        "perception/face-tracks.json",
        "perception/object-tracks.json",
        "events.jsonl"
      ]
    },
    {
      "camera_id": "laptop-camera",
      "role": "global-view",
      "device_kind": "builtin",
      "frame_format": "jpeg",
      "capture_profile": "1280x720@15",
      "required_for": [
        "demo-full-flow",
        "demo-sorting",
        "demo-conversation-grasp",
        "demo-dangerous-action",
        "demo-real-risk-slice"
      ],
      "evidence_artifacts": [
        "perception/frame-sources.json",
        "perception/face-tracks.json",
        "perception/object-tracks.json",
        "events.jsonl"
      ]
    }
  ],
  "scenario_profiles": {
    "demo-full-flow": {
