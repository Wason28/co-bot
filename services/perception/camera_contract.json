    },
    "demo-sorting": {
      "required_camera_ids": [
        "wrist-camera",
        "laptop-camera"
      ],
      "face_tracking": false,
      "object_tracking": true,
      "emotion_motion": true,
      "evidence_files": [
        "perception/frame-sources.json",
        "perception/object-tracks.json",
        "video/run.mp4"
      ]
    },
    "demo-conversation-grasp": {
      "required_camera_ids": [
        "wrist-camera",
        "laptop-camera"
      ],
      "face_tracking": true,
      "object_tracking": true,
      "emotion_motion": true,
      "evidence_files": [
        "perception/frame-sources.json",
        "perception/face-tracks.json",
        "perception/object-tracks.json",
        "video/run.mp4"
      ]
    },
    "demo-real-risk-slice": {
      "required_camera_ids": [
        "wrist-camera",
        "laptop-camera"
      ],
      "face_tracking": true,
      "object_tracking": true,
      "emotion_motion": false,
      "evidence_files": [
        "perception/frame-sources.json",
        "video/run.mp4"
      ]
    }
  },
  "real_risk_slice": {
    "scenario_id": "demo-real-risk-slice",
    "required_camera_ids": [
      "wrist-camera",
      "laptop-camera"
    ],
    "sync_mode": "best-effort-timestamp",
    "evidence_file": "perception/frame-sources.json"
  }
