{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Co-Bot Policy Gate Decision",
  "type": "object",
  "required": [
    "scenario_id",
    "risk_level",
    "requires_confirmation",
    "allowed_next_states",
    "decision_reason"
  ],
  "properties": {
    "scenario_id": {"type": "string"},
    "risk_level": {"enum": ["safe", "confirm", "dangerous"]},
    "requires_confirmation": {"type": "boolean"},
    "allowed_next_states": {
      "type": "array",
      "items": {
        "enum": [
          "gated",
          "awaiting_confirm",
          "approved",
          "rejected",
          "executing",
          "completed",
          "aborted",
          "resumed"
        ]
      }
    },
    "decision_reason": {"type": "string"}
  },
  "additionalProperties": false
}
